#!/usr/bin/env bash

echo "=> git fetch --all --prune"
git fetch --all --prune

main_branch=$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@')

# Collect remote branches merged into main (excluding permanent branches) and greenkeeper branches
mapfile -t branches < <(
  {
    git branch -r --merged "$main_branch" | grep -Ev 'master$|main$|develop$|HEAD'
    git branch -r | grep 'greenkeeper/'
  } | sed 's/^[[:space:]]*//' | sort -u
)

# Group branch names by remote
declare -A remote_branches
for branch in "${branches[@]}"; do
  remote="${branch%%/*}"
  name="${branch#*/}"
  [[ -z "$remote" || -z "$name" ]] && continue
  if [[ -v "remote_branches[$remote]" ]]; then
    remote_branches["$remote"]+=" $name"
  else
    remote_branches["$remote"]="$name"
  fi
done

for remote in "${!remote_branches[@]}"; do
  skip=$(git config --get "remote.${remote}.skipcleanup" 2>/dev/null || true)
  [[ "$skip" == "true" ]] && continue

  read -ra branches_to_delete <<< "${remote_branches[$remote]}"

  while true; do
    read -rp "=> Cleaning remote '$remote', continue? [y,n,s] " input
    case "${input,,}" in
      y|yes)
        echo "=> git push --no-verify $remote --delete ${branches_to_delete[*]}"
        git push --no-verify "$remote" --delete "${branches_to_delete[@]}"
        break
        ;;
      n|no)
        echo "=> Skipped."
        break
        ;;
      s|skip)
        echo "=> git config remote.${remote}.skipcleanup true"
        git config "remote.${remote}.skipcleanup" 'true'
        echo "=> Skipped (permanent)."
        break
        ;;
    esac
  done
done
